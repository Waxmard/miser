{
  "name": "miser-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "icons:generate": "node scripts/build-simple-icons-map.mjs",
    "dev": "node scripts/build-simple-icons-map.mjs && vite dev",
    "build": "node scripts/build-simple-icons-map.mjs && vite build",
    "postbuild": "echo > dist/.gitkeep",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "check": "node scripts/build-simple-icons-map.mjs && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "prepare": "husky"
  },
  "dependencies": {
    "chart.js": "^4.4.7",
    "marked": "^18.0.2",
    "simple-icons": "^16.15.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.16.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@typescript-eslint/parser": "^8.19.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-sonarjs": "^3.0.1",
    "eslint-plugin-svelte": "^2.46.1",
    "eslint-plugin-unicorn": "^56.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.2",
    "svelte": "^5.17.3",
    "svelte-check": "^4.1.1",
    "svelte-eslint-parser": "^0.43.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "lint-staged": {
    "*.{js,ts,svelte}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,html}": "prettier --write"
  }
}
